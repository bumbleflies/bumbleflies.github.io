{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "published": {
      "default": true,
      "type": "boolean"
    },
    "eyebrow": {
      "type": "string"
    },
    "heading": {
      "type": "string"
    },
    "subheading": {
      "type": "string"
    },
    "intro": {
      "type": "string"
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "number": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "tag": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "bullets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "formats": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              },
              "required": [
                "kind",
                "label"
              ]
            }
          }
        },
        "required": [
          "number",
          "title",
          "tag",
          "description",
          "bullets",
          "formats"
        ]
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "number": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "number",
          "title",
          "description"
        ]
      }
    },
    "comparisonRows": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "fragmented": {
            "type": "string"
          },
          "integrated": {
            "type": "string"
          }
        },
        "required": [
          "label",
          "fragmented",
          "integrated"
        ]
      }
    },
    "problemTitle": {
      "type": "string"
    },
    "problemBullets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "solutionTitle": {
      "type": "string"
    },
    "solutionBullets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ctaHeading": {
      "type": "string"
    },
    "ctaHeading_em": {
      "type": "string"
    },
    "ctaBody": {
      "type": "string"
    },
    "ctaText": {
      "type": "string"
    },
    "cta": {
      "type": "object",
      "properties": {
        "text": {
          "type": "string"
        },
        "link": {
          "type": "string"
        }
      },
      "required": [
        "text",
        "link"
      ]
    },
    "quote": {
      "type": "string"
    },
    "quoteCite": {
      "type": "string"
    },
    "lang": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title"
  ]
}