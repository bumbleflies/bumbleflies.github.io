{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "service": {
      "type": "string",
      "enum": [
        "Talk",
        "Decide",
        "Build & Embed",
        "Full Journey"
      ]
    },
    "company": {
      "type": "string"
    },
    "duration": {
      "type": "string"
    },
    "outcome": {
      "type": "string"
    },
    "quote": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "published": {
      "default": true,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "service",
    "company",
    "outcome",
    "quote"
  ]
}