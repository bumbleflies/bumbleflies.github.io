{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "author": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "quote": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "published": {
      "default": true,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "author",
    "role",
    "company",
    "quote"
  ]
}