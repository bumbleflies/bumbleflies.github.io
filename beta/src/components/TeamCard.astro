---
interface Props {
  name: string;
  role: string;
  bio: string;
  image: string;
}

const { name, role, bio, image } = Astro.props;
---

<article class="a-team-card">
  {image && (
    <img
      src={image}
      alt={name}
      class="a-team-card__image"
    />
  )}
  <h3 class="a-team-card__name">{name}</h3>
  <p class="a-team-card__role">{role}</p>
  <p class="a-team-card__bio">{bio}</p>
</article>

<style>
  .a-team-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: center;
  }

  .a-team-card__image {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: 0.5rem;
  }

  .a-team-card__name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin: 0;
    color: #1a1a1a;
  }

  .a-team-card__role {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #d4a574;
    margin: 0;
  }

  .a-team-card__bio {
    font-size: 1rem;
    line-height: 1.6;
    color: #4a4a4a;
    margin: 0;
  }

  @media (max-width: 768px) {
    .a-team-card {
      gap: 0.75rem;
    }

    .a-team-card__name {
      font-size: 1.25rem;
    }

    .a-team-card__role {
      font-size: 0.75rem;
    }

    .a-team-card__bio {
      font-size: 0.95rem;
    }
  }

  @media (max-width: 375px) {
    .a-team-card__name {
      font-size: 1.125rem;
    }

    .a-team-card__bio {
      font-size: 0.875rem;
    }
  }
</style>
