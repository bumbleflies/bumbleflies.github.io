---
import { getCollection } from 'astro:content';
import CaseStudyCard from './CaseStudyCard.astro';

interface Props {
  heading: string;
  eyebrow: string;
  ctaText: string;
  lang: 'DE' | 'EN';
}

const { heading, eyebrow, ctaText, lang } = Astro.props;

// Get 4 featured case studies (showing variety of service types)
const allCases = await getCollection('case-studies', ({ data }) => data.published);
const featured = allCases.slice(0, 4);
---

<section class="a-case-studies-preview">
  <div class="bf-container">
    <div class="a-case-studies-preview__header">
      <span class="a-case-studies-preview__eyebrow">{eyebrow}</span>
      <h2 class="a-case-studies-preview__heading">{heading}</h2>
    </div>

    <div class="a-case-studies-preview__grid">
      {featured.map(study => (
        <CaseStudyCard
          title={study.data.title}
          company={study.data.company}
          service={study.data.service}
          quote={study.data.quote}
          slug={study.slug}
        />
      ))}
    </div>

    <div class="a-case-studies-preview__cta">
      <a href={lang === 'DE' ? '/case-studies' : '/en/case-studies/'} class="bf-cta">
        {ctaText}
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .a-case-studies-preview {
    padding: var(--spacing-xl) 0;
    background: #fafafa;
  }

  .a-case-studies-preview__header {
    margin-bottom: var(--spacing-xl);
    text-align: center;
  }

  .a-case-studies-preview__eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #999;
    margin-bottom: var(--spacing-md);
    font-weight: 600;
  }

  .a-case-studies-preview__heading {
    font-family: var(--font-display);
    font-size: 2rem;
    margin: 0;
    color: var(--ink);
    line-height: 1.2;
  }

  .a-case-studies-preview__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .a-case-studies-preview__cta {
    text-align: center;
  }

  @media (max-width: 1024px) {
    .a-case-studies-preview__grid {
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    }
  }

  @media (max-width: 768px) {
    .a-case-studies-preview {
      padding: var(--spacing-lg) 0;
    }

    .a-case-studies-preview__heading {
      font-size: 1.5rem;
    }

    .a-case-studies-preview__grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
      margin-bottom: var(--spacing-lg);
    }
  }
</style>
