---
interface Props {
  text: string;
  cite: string;
  lang?: 'DE' | 'EN';
}

const { text, cite, lang = 'DE' } = Astro.props;
---

<section class="bf-section" style="padding: 120px 0;">
  <div class="bf-container" style="text-align: center;">
    <p class="a-quote">{text}</p>
    <span class="a-quote__cite">{cite}</span>
  </div>
</section>

<style>
  .a-quote {
    font-style: italic;
    color: var(--ink);
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.6;
    max-width: 700px;
  }

  .a-quote__cite {
    font-size: 0.875rem;
    color: #999;
    margin-top: 1.25rem;
    display: block;
  }
</style>
