---
interface Props {
  text: string;
  cite: string;
  lang?: 'DE' | 'EN';
}

const { text, cite, lang = 'DE' } = Astro.props;
---

<section class="bf-section" style="padding: 120px 0;">
  <div class="bf-container" style="text-align: center;">
    <p class="a-quote">{text}</p>
    <span class="a-quote__cite">{cite}</span>
  </div>
</section>

<style>
  .a-quote {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    line-height: var(--lh-relaxed);
    letter-spacing: -0.015em;
    max-width: 900px;
    margin: 0 auto;
    color: var(--ink);
  }

  .a-quote__cite {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--ls-mono);
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-top: 32px;
    display: block;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .a-quote {
      font-size: var(--text-3xl);
    }
  }
</style>
