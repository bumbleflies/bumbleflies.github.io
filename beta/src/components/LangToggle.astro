---
interface Props {
  lang: 'DE' | 'EN';
  onLangChange?: (lang: 'DE' | 'EN') => void;
  id?: string;
}

const { lang, id = 'lang-toggle' } = Astro.props;
---

<div class="bf-lang" role="group" aria-label="Language">
  <button
    class={`lang-btn ${lang === 'DE' ? 'is-active' : ''}`}
    data-lang="DE"
    aria-pressed={lang === 'DE'}
  >
    DE
  </button>
  <button
    class={`lang-btn ${lang === 'EN' ? 'is-active' : ''}`}
    data-lang="EN"
    aria-pressed={lang === 'EN'}
  >
    EN
  </button>
</div>

<script>
  const buttons = document.querySelectorAll('.lang-btn');
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = btn.getAttribute('data-lang');
      buttons.forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');

      // Dispatch custom event for parent to listen to
      window.dispatchEvent(new CustomEvent('lang-change', { detail: { lang } }));
    });
  });
</script>

<style>
  .bf-lang {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--rule);
    border-radius: var(--radius-full);
    padding: var(--space-xs);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }

  .lang-btn {
    background: transparent;
    border: 0;
    color: var(--ink-soft);
    padding: var(--space-xs) 9px;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    text-transform: uppercase;
    cursor: pointer;
    transition: all var(--duration-fast);
  }

  .lang-btn.is-active {
    background: var(--ink);
    color: var(--paper);
  }
</style>
