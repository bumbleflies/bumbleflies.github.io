---
import { getCollection } from 'astro:content';
import TestimonialCard from './TestimonialCard.astro';

interface Props {
  heading?: string;
  eyebrow?: string;
}

const { heading, eyebrow } = Astro.props;

const testimonials = await getCollection('testimonials');
const published = testimonials.filter(t => t.data.published);
---

<section class="a-testimonials-grid">
  <div class="bf-container">
    {eyebrow && <p class="a-testimonials-grid__eyebrow">{eyebrow}</p>}
    {heading && <h2 class="a-testimonials-grid__heading">{heading}</h2>}
    <div class="a-testimonials-grid__grid">
      {published.map(testimonial => (
        <TestimonialCard
          author={testimonial.data.author}
          role={testimonial.data.role}
          company={testimonial.data.company}
          quote={testimonial.data.quote}
          image={testimonial.data.image}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .a-testimonials-grid {
    padding: var(--spacing-xl) 0;
  }

  .a-testimonials-grid__eyebrow {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
    margin: 0 0 var(--space-md) 0;
    text-align: center;
  }

  .a-testimonials-grid__heading {
    font-family: var(--font-display);
    font-size: 2rem;
    margin: 0 0 var(--space-2xl) 0;
    color: var(--ink);
    text-align: center;
  }

  .a-testimonials-grid__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-xl);
  }

  @media (max-width: 768px) {
    .a-testimonials-grid {
      padding: var(--spacing-lg) 0;
    }

    .a-testimonials-grid__heading {
      font-size: 1.5rem;
      margin-bottom: var(--space-xl);
    }

    .a-testimonials-grid__grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>
