---
interface RiskItem {
  title: string;
  description: string;
  mitigation: string;
}

interface Props {
  items: RiskItem[];
  lang?: 'DE' | 'EN';
}

const { items, lang = 'DE' } = Astro.props;
---

<div class="a-risk-accordion">
  {items.map((item, index) => (
    <div class="a-risk-accordion__item" key={index}>
      <button class="a-risk-accordion__trigger" data-index={index} aria-expanded="false">
        <span class="a-risk-accordion__title" data-de={item.title} data-en={item.title}>
          {item.title}
        </span>
        <svg class="a-risk-accordion__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
      <div class="a-risk-accordion__panel" data-index={index} hidden>
        <div class="a-risk-accordion__content">
          <div class="a-risk-accordion__section">
            <h4 class="a-risk-accordion__label">Description</h4>
            <p class="a-risk-accordion__text" data-de={item.description} data-en={item.description}>
              {item.description}
            </p>
          </div>
          <div class="a-risk-accordion__section">
            <h4 class="a-risk-accordion__label">Mitigation</h4>
            <p class="a-risk-accordion__text" data-de={item.mitigation} data-en={item.mitigation}>
              {item.mitigation}
            </p>
          </div>
        </div>
      </div>
    </div>
  ))}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('.a-risk-accordion__trigger') as NodeListOf<HTMLButtonElement>;
    const panels = document.querySelectorAll('.a-risk-accordion__panel') as NodeListOf<HTMLElement>;

    triggers.forEach((trigger, index) => {
      trigger.addEventListener('click', () => {
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';

        // Close all panels
        triggers.forEach(t => t.setAttribute('aria-expanded', 'false'));
        panels.forEach(p => p.setAttribute('hidden', ''));

        // Open clicked panel if it wasn't open
        if (!isExpanded) {
          trigger.setAttribute('aria-expanded', 'true');
          const panel = document.querySelector(`.a-risk-accordion__panel[data-index="${index}"]`) as HTMLElement;
          if (panel) {
            panel.removeAttribute('hidden');
          }
        }
      });
    });

    // Language toggle support
    window.addEventListener('lang:toggle', (e: any) => {
      const newLang = e.detail?.lang || 'DE';

      const titles = document.querySelectorAll('.a-risk-accordion__title') as NodeListOf<HTMLElement>;
      titles.forEach(title => {
        const deValue = title.getAttribute('data-de');
        const enValue = title.getAttribute('data-en');
        title.textContent = newLang === 'DE' ? deValue : enValue;
      });

      const texts = document.querySelectorAll('.a-risk-accordion__text') as NodeListOf<HTMLElement>;
      texts.forEach(text => {
        const deValue = text.getAttribute('data-de');
        const enValue = text.getAttribute('data-en');
        text.textContent = newLang === 'DE' ? deValue : enValue;
      });
    });
  });
</script>

<style>
  .a-risk-accordion {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 900px;
  }

  .a-risk-accordion__item {
    border: 1px solid var(--rule);
    border-radius: 0.5rem;
    overflow: hidden;
    transition: box-shadow var(--duration-normal);
  }

  .a-risk-accordion__item:hover {
    box-shadow: 0 4px 12px rgba(26, 23, 20, 0.08);
  }

  .a-risk-accordion__trigger {
    width: 100%;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: var(--paper);
    border: none;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
    transition: background var(--duration-normal);
  }

  .a-risk-accordion__trigger:hover {
    background: rgba(212, 165, 116, 0.05);
  }

  .a-risk-accordion__trigger[aria-expanded="true"] {
    background: rgba(212, 165, 116, 0.08);
  }

  .a-risk-accordion__title {
    text-align: left;
    flex: 1;
  }

  .a-risk-accordion__icon {
    flex-shrink: 0;
    color: var(--accent);
    transition: transform var(--duration-normal);
  }

  .a-risk-accordion__trigger[aria-expanded="true"] .a-risk-accordion__icon {
    transform: rotate(180deg);
  }

  .a-risk-accordion__panel {
    border-top: 1px solid var(--rule);
  }

  .a-risk-accordion__panel[hidden] {
    display: none;
  }

  .a-risk-accordion__content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .a-risk-accordion__section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .a-risk-accordion__label {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
    margin: 0;
    font-weight: 600;
  }

  .a-risk-accordion__text {
    font-size: 1rem;
    line-height: var(--lh-body);
    color: var(--ink-soft);
    margin: 0;
  }

  @media (max-width: 768px) {
    .a-risk-accordion {
      gap: 0.75rem;
    }

    .a-risk-accordion__trigger {
      padding: 1.25rem;
      font-size: 0.95rem;
    }

    .a-risk-accordion__content {
      padding: 1.25rem;
      gap: 1rem;
    }

    .a-risk-accordion__text {
      font-size: 0.95rem;
    }
  }

  @media (max-width: 480px) {
    .a-risk-accordion__trigger {
      padding: 1rem;
      font-size: 0.9rem;
      gap: 0.75rem;
    }

    .a-risk-accordion__content {
      padding: 1rem;
    }

    .a-risk-accordion__text {
      font-size: 0.9rem;
    }

    .a-risk-accordion__icon {
      width: 20px;
      height: 20px;
    }
  }
</style>
