---
import { getCollection } from 'astro:content';

const testimonials = await getCollection('testimonials', ({ data }) => data.published);
---

<section class="a-testimonial-carousel">
  <div class="bf-container">
    <h2 class="a-testimonial-carousel__heading">Was Kunden über uns sagen</h2>
    <div class="a-testimonial-carousel__track">
      {testimonials.length > 0 ? (
        testimonials.map((testimonial, index) => (
          <article
            class="a-testimonial-carousel__slide"
            data-index={index}
          >
            <blockquote class="a-testimonial-carousel__quote">
              "{testimonial.data.quote}"
            </blockquote>
            <footer class="a-testimonial-carousel__attribution">
              <strong>{testimonial.data.author}</strong>
              <br />
              {testimonial.data.role} at {testimonial.data.company}
            </footer>
          </article>
        ))
      ) : (
        <p class="a-testimonial-carousel__empty">Testimonials coming soon.</p>
      )}
    </div>
  </div>
</section>

<style>
  .a-testimonial-carousel {
    padding: var(--space-4xl) 0;
    background: var(--paper);
  }

  .a-testimonial-carousel__heading {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    margin-bottom: var(--space-3xl);
    text-align: center;
    color: var(--ink);
  }

  .a-testimonial-carousel__track {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: var(--space-xl);
  }

  .a-testimonial-carousel__slide {
    background: var(--bg);
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--rule);
  }

  .a-testimonial-carousel__quote {
    font-size: var(--text-lg);
    font-style: italic;
    line-height: var(--lh-body);
    margin: 0 0 var(--space-lg) 0;
    color: var(--ink);
  }

  .a-testimonial-carousel__attribution {
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }

  .a-testimonial-carousel__empty {
    grid-column: 1 / -1;
    text-align: center;
    color: var(--ink-soft);
    padding: var(--space-3xl) 0;
  }

  @media (max-width: 768px) {
    .a-testimonial-carousel__heading {
      font-size: var(--text-2xl);
    }

    .a-testimonial-carousel__track {
      grid-template-columns: 1fr;
    }
  }
</style>
