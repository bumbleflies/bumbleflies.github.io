---
import { getCollection } from 'astro:content';
import TeamCard from './TeamCard.astro';

const team = await getCollection('team');
const sorted = team.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---

<section class="a-team-profiles">
  <div class="bf-container">
    <h2 class="a-team-profiles__heading">Unser Team</h2>
    <div class="a-team-profiles__grid">
      {sorted.map(member => (
        <TeamCard
          name={member.data.name}
          role={member.data.role}
          bio={member.data.bio}
          image={member.data.image}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .a-team-profiles {
    padding: var(--spacing-xl) 0;
  }

  .a-team-profiles__heading {
    font-family: var(--font-display);
    font-size: 2rem;
    margin-bottom: 3rem;
    color: var(--ink);
    text-align: center;
  }

  .a-team-profiles__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .a-team-profiles__grid {
      grid-template-columns: 1fr;
    }

    .a-team-profiles__heading {
      font-size: 1.5rem;
    }
  }
</style>
