---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import LangToggle from '../../components/LangToggle.astro';

export async function getStaticPaths() {
  const caseStudies = await getCollection('case-studies', ({ data }) => data.published);
  return caseStudies.map(study => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

const { study } = Astro.props;
const { Content } = await study.render();
---

<Layout title={study.data.title}>
  <Nav slot="nav">
    <LangToggle slot="lang" />
  </Nav>
  <article class="a-case-study-detail bf-container">
      <a href="/case-studies" class="a-case-study-detail__back">← Alle Fallstudien</a>

      <header class="a-case-study-detail__header">
        <h1 class="a-case-study-detail__title">{study.data.title}</h1>
        <p class="a-case-study-detail__company">{study.data.company}</p>
        <span class="a-case-study-detail__service">{study.data.service}</span>
        {study.data.duration && (
          <p class="a-case-study-detail__duration">{study.data.duration}</p>
        )}
      </header>

      <div class="a-case-study-detail__content">
        <Content />
      </div>

      <aside class="a-case-study-detail__quote">
        <blockquote>"{study.data.quote}"</blockquote>
      </aside>

      <div class="a-case-study-detail__cta">
        <a href="mailto:info@bumbleflies.de" class="bf-cta">Erstes Gespräch buchen</a>
      </div>
    </article>
  <Footer slot="footer" />
</Layout>

<style>
  .a-case-study-detail {
    padding: var(--spacing-xl) var(--space-3xl);
  }

  .a-case-study-detail__back {
    display: inline-block;
    margin-bottom: var(--spacing-lg);
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
    transition: opacity 150ms cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .a-case-study-detail__back:hover {
    opacity: 0.8;
  }

  .a-case-study-detail__header {
    margin-bottom: var(--spacing-xl);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid #e0dcd4;
  }

  .a-case-study-detail__title {
    font-family: var(--font-display);
    font-size: 3rem;
    line-height: 1.1;
    margin: 0 0 var(--spacing-md) 0;
    color: var(--ink);
  }

  .a-case-study-detail__company {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: #666;
    margin: 0 0 var(--spacing-md) 0;
    font-weight: 500;
  }

  .a-case-study-detail__service {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.375rem 0.875rem;
    background: var(--accent);
    color: white;
    border-radius: 0;
    margin-bottom: var(--spacing-md);
    font-weight: 600;
  }

  .a-case-study-detail__duration {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: #999;
    margin: 0;
  }

  .a-case-study-detail__content {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: var(--spacing-xl);
    color: #333;
  }

  .a-case-study-detail__content :global(h2) {
    font-family: var(--font-display);
    font-size: 1.75rem;
    line-height: 1.2;
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
    color: var(--ink);
  }

  .a-case-study-detail__content :global(p) {
    margin-bottom: var(--spacing-md);
  }

  .a-case-study-detail__content :global(strong) {
    color: var(--ink);
    font-weight: 600;
  }

  .a-case-study-detail__content :global(ul),
  .a-case-study-detail__content :global(ol) {
    margin: var(--spacing-lg) 0;
    padding-left: 2rem;
  }

  .a-case-study-detail__content :global(li) {
    margin-bottom: 0.5rem;
  }

  .a-case-study-detail__quote {
    padding: var(--spacing-lg);
    background: #faf7f0;
    border-left: 3px solid var(--accent);
    margin: var(--spacing-xl) 0;
    font-style: italic;
    font-size: 1.125rem;
    line-height: 1.6;
    color: #333;
    font-family: var(--font-body);
  }

  .a-case-study-detail__quote blockquote {
    margin: 0;
  }

  .a-case-study-detail__cta {
    text-align: center;
    margin: var(--spacing-xl) 0;
  }

  @media (max-width: 768px) {
    .a-case-study-detail {
      padding: var(--spacing-lg) 0;
    }

    .a-case-study-detail__title {
      font-size: 1.875rem;
    }

    .a-case-study-detail__quote {
      font-size: 1rem;
      padding: var(--spacing-md);
    }
  }
</style>
