---
import Layout from '../components/Layout.astro';
import Nav from '../components/Nav.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import CTAStrip from '../components/CTAStrip.astro';
import Footer from '../components/Footer.astro';

interface ContentSet {
  pageTitle: string;
  heading: string;
  intro: string;
  comparisonRows: Array<{
    label: string;
    fragmented: string;
    integrated: string;
  }>;
  ctaHeading: string;
  ctaHeading_em: string;
  ctaBody: string;
  ctaText: string;
}

const content: Record<'DE' | 'EN', ContentSet> = {
  DE: {
    pageTitle: 'Why Bumbleflies',
    heading: 'Integriert, nicht fragmentiert.',
    intro: 'Die meisten Transformation Services sind Staffelläufe...',
    comparisonRows: [
      {
        label: 'Wer führt?',
        fragmented: 'mehrere',
        integrated: 'ein Team'
      },
      {
        label: 'Ziel?',
        fragmented: 'Phasen abrechnen',
        integrated: 'Lösung die funktioniert'
      },
      {
        label: 'Lernen zwischen Phasen?',
        fragmented: 'nein',
        integrated: 'ja'
      },
      {
        label: 'Adoption?',
        fragmented: 'am Ende',
        integrated: 'von Anfang an'
      }
    ],
    ctaHeading: 'Bereit für',
    ctaHeading_em: 'Transformation?',
    ctaBody: 'Schreiben Sie uns oder buchen Sie ein erstes Gespräch. Wir freuen uns auf den Austausch mit Ihnen.',
    ctaText: 'Erstes Gespräch vereinbaren'
  },
  EN: {
    pageTitle: 'Why Bumbleflies',
    heading: 'Integrated, not fragmented.',
    intro: 'Most transformation services are relay races...',
    comparisonRows: [
      {
        label: 'Who leads?',
        fragmented: 'multiple',
        integrated: 'one team'
      },
      {
        label: 'Goal?',
        fragmented: 'bill phases',
        integrated: 'solution that works'
      },
      {
        label: 'Learning between phases?',
        fragmented: 'no',
        integrated: 'yes'
      },
      {
        label: 'Adoption?',
        fragmented: 'at end',
        integrated: 'from start'
      }
    ],
    ctaHeading: 'Ready for',
    ctaHeading_em: 'Transformation?',
    ctaBody: 'Get in touch or book your first call. We look forward to speaking with you.',
    ctaText: 'Book a first call'
  }
};

let lang: 'DE' | 'EN' = 'DE';
const deContent = content.DE;
const enContent = content.EN;
---

<Layout title={deContent.pageTitle}>
  <div slot="nav">
    <Nav lang={lang} />
  </div>

  <main>
    <section class="a-why-bumbleflies-hero">
      <div class="bf-container">
        <h1 class="a-why-bumbleflies-hero__heading" data-de={deContent.heading} data-en={enContent.heading}>
          {deContent.heading}
        </h1>
        <p class="a-why-bumbleflies-hero__intro" data-de={deContent.intro} data-en={enContent.intro}>
          {deContent.intro}
        </p>
      </div>
    </section>

    <section class="a-why-bumbleflies-table bf-section">
      <div class="bf-container">
        <div class="a-comparison-wrapper" data-de-rows={JSON.stringify(deContent.comparisonRows)} data-en-rows={JSON.stringify(enContent.comparisonRows)}>
          <ComparisonTable rows={deContent.comparisonRows} lang={lang} />
        </div>
      </div>
    </section>

    <div data-de-cta={JSON.stringify({heading: deContent.ctaHeading, headingEm: deContent.ctaHeading_em, body: deContent.ctaBody, ctaText: deContent.ctaText})} data-en-cta={JSON.stringify({heading: enContent.ctaHeading, headingEm: enContent.ctaHeading_em, body: enContent.ctaBody, ctaText: enContent.ctaText})} class="bf-cta-container">
      <CTAStrip
        heading={deContent.ctaHeading}
        headingEm={deContent.ctaHeading_em}
        body={deContent.ctaBody}
        ctaText={deContent.ctaText}
        lang={lang}
      />
    </div>
  </main>

  <div slot="footer">
    <Footer />
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    window.addEventListener('lang:toggle', (e: any) => {
      const newLang = e.detail?.lang || 'DE';

      // Update hero section
      const heroHeading = document.querySelector('.a-why-bumbleflies-hero__heading') as HTMLElement;
      if (heroHeading) {
        const deValue = heroHeading.getAttribute('data-de');
        const enValue = heroHeading.getAttribute('data-en');
        heroHeading.textContent = newLang === 'DE' ? deValue : enValue;
      }

      const heroIntro = document.querySelector('.a-why-bumbleflies-hero__intro') as HTMLElement;
      if (heroIntro) {
        const deValue = heroIntro.getAttribute('data-de');
        const enValue = heroIntro.getAttribute('data-en');
        heroIntro.textContent = newLang === 'DE' ? deValue : enValue;
      }

      // Update table headers
      const headers = document.querySelectorAll('.a-comparison-table__header') as NodeListOf<HTMLElement>;
      headers.forEach(header => {
        const deValue = header.getAttribute('data-de');
        const enValue = header.getAttribute('data-en');
        header.textContent = newLang === 'DE' ? deValue : enValue;
      });

      // Update table cells
      const cells = document.querySelectorAll('.a-comparison-table__label, .a-comparison-table__cell') as NodeListOf<HTMLElement>;
      cells.forEach(cell => {
        const deValue = cell.getAttribute('data-de');
        const enValue = cell.getAttribute('data-en');
        cell.textContent = newLang === 'DE' ? deValue : enValue;
      });

      // Update CTA section
      const ctaDiv = document.querySelector('.bf-cta-container') as HTMLElement;
      if (ctaDiv) {
        const deCta = JSON.parse(ctaDiv.getAttribute('data-de-cta') || '{}');
        const enCta = JSON.parse(ctaDiv.getAttribute('data-en-cta') || '{}');
        const ctaData = newLang === 'DE' ? deCta : enCta;

        const ctaSection = ctaDiv.querySelector('section') as HTMLElement;
        if (ctaSection) {
          const heading = ctaSection.querySelector('h2') as HTMLElement;
          const body = ctaSection.querySelector('p') as HTMLElement;
          const link = ctaSection.querySelector('.bf-cta') as HTMLElement;

          if (heading) {
            heading.innerHTML = `${ctaData.heading}<em style="font-style: italic; color: var(--accent);">${ctaData.headingEm}</em>`;
          }
          if (body) {
            body.textContent = ctaData.body;
          }
          if (link) {
            const svg = link.querySelector('svg');
            link.textContent = ctaData.ctaText;
            if (svg) link.appendChild(svg);
          }
        }
      }
    });
  });
</script>

<style>
  .a-why-bumbleflies-hero {
    padding: 4rem 0;
    background: var(--paper);
  }

  .a-why-bumbleflies-hero__heading {
    font-family: var(--font-display);
    font-size: 3rem;
    margin: 0 0 1.5rem 0;
    color: var(--ink);
    max-width: 900px;
  }

  .a-why-bumbleflies-hero__intro {
    font-size: 1.25rem;
    color: var(--ink-soft);
    max-width: 700px;
    margin: 0;
  }

  .a-why-bumbleflies-table {
    padding: 4rem 0;
  }

  .a-comparison-wrapper {
    max-width: 900px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .a-why-bumbleflies-hero {
      padding: 2.5rem 0;
    }

    .a-why-bumbleflies-hero__heading {
      font-size: 2rem;
      margin-bottom: 1rem;
    }

    .a-why-bumbleflies-hero__intro {
      font-size: 1rem;
    }

    .a-why-bumbleflies-table {
      padding: 2.5rem 0;
    }
  }

  @media (max-width: 480px) {
    .a-why-bumbleflies-hero {
      padding: 1.5rem 0;
    }

    .a-why-bumbleflies-hero__heading {
      font-size: 1.5rem;
    }

    .a-why-bumbleflies-hero__intro {
      font-size: 0.95rem;
    }

    .a-why-bumbleflies-table {
      padding: 1.5rem 0;
    }
  }
</style>
