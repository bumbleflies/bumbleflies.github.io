---
import Layout from '../components/Layout.astro';
import Nav from '../components/Nav.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import CTAStrip from '../components/CTAStrip.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const dePages = await getCollection('pages', ({ slug }) => slug === 'why-bumbleflies');
const enPages = await getCollection('pages', ({ slug }) => slug === 'en/why-bumbleflies');

const dePage = dePages[0];
const enPage = enPages[0];

if (!dePage || !enPage) {
  throw new Error('Why Bumbleflies content not found in collection');
}

const deContent = dePage.data;
const enContent = enPage.data;

let lang: 'DE' | 'EN' = 'DE';
---

<Layout title={deContent.title}>
  <div slot="nav">
    <Nav lang={lang} />
  </div>

  <section class="a-why-bumbleflies-hero">
      <div class="bf-container">
        <h1 class="a-why-bumbleflies-hero__heading" data-de={deContent.heading} data-en={enContent.heading}>
          {deContent.heading}
        </h1>
        <p class="a-why-bumbleflies-hero__intro" data-de={deContent.intro} data-en={enContent.intro}>
          {deContent.intro}
        </p>
      </div>
    </section>

    <section class="a-why-bumbleflies-table bf-section">
      <div class="bf-container">
        <div class="a-comparison-wrapper" data-de-rows={JSON.stringify(deContent.comparisonRows)} data-en-rows={JSON.stringify(enContent.comparisonRows)}>
          <ComparisonTable deRows={deContent.comparisonRows} enRows={enContent.comparisonRows} lang={lang} />
        </div>
      </div>
    </section>

    <div data-de-cta={JSON.stringify({heading: deContent.ctaHeading, headingEm: deContent.ctaHeading_em, body: deContent.ctaBody, ctaText: deContent.ctaText})} data-en-cta={JSON.stringify({heading: enContent.ctaHeading, headingEm: enContent.ctaHeading_em, body: enContent.ctaBody, ctaText: enContent.ctaText})} class="bf-cta-container">
      <CTAStrip
        heading={deContent.ctaHeading}
        headingEm={deContent.ctaHeading_em}
        body={deContent.ctaBody}
        ctaText={deContent.ctaText}
        lang={lang}
      />
    </div>

  <div slot="footer">
    <Footer />
  </div>
</Layout>

<style>
  .a-why-bumbleflies-hero {
    padding: 4rem 0;
    background: var(--paper);
  }

  .a-why-bumbleflies-hero__heading {
    font-family: var(--font-display);
    font-size: 3rem;
    margin: 0 0 1.5rem 0;
    color: var(--ink);
    max-width: 900px;
  }

  .a-why-bumbleflies-hero__intro {
    font-size: 1.25rem;
    color: var(--ink-soft);
    max-width: 700px;
    margin: 0;
  }

  .a-why-bumbleflies-table {
    padding: 4rem 0;
  }

  .a-comparison-wrapper {
    max-width: 900px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .a-why-bumbleflies-hero {
      padding: 2.5rem 0;
    }

    .a-why-bumbleflies-hero__heading {
      font-size: 2rem;
      margin-bottom: 1rem;
    }

    .a-why-bumbleflies-hero__intro {
      font-size: 1rem;
    }

    .a-why-bumbleflies-table {
      padding: 2.5rem 0;
    }
  }

  @media (max-width: 480px) {
    .a-why-bumbleflies-hero {
      padding: 1.5rem 0;
    }

    .a-why-bumbleflies-hero__heading {
      font-size: 1.5rem;
    }

    .a-why-bumbleflies-hero__intro {
      font-size: 0.95rem;
    }

    .a-why-bumbleflies-table {
      padding: 1.5rem 0;
    }
  }
</style>
