---
import Layout from '../components/Layout.astro';
---

<Layout title="bumbleflies — From Conversation to Code">
  <main>
    <h1>From Conversation to Code — and Actually Using It</h1>
    <p>Integration transformation shop: Talk → Decide → Build → Embed</p>
    <p style="font-size: 0.9em; color: #666; margin-top: 2rem;">
      This is the NEW site under development. See the <a href="https://bumbleflies.de">current site</a> for production content.
    </p>
  </main>
</Layout>

<style>
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    line-height: 1.6;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  a {
    color: #0066cc;
  }
</style>
